{
  "version": 2,
  "env": {
    "NODE_ENV": "production",
    "PNPM_HOME": ".pnpm"
  },
  "buildCommand": "pnpm run build",
  "installCommand": "pnpm install --frozen-lockfile",
  "framework": "vite",
  "routes": [
    {
      "src": "^/(?!api).*",
      "dest": "/index.html",
      "status": 200
    }
  ]
}

